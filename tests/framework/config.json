{
  "base_url": "http://localhost:8080",
  "admin_key": "local-dev-fallback-key",
  "mailpit_url": "http://localhost:8025",
  "db_container": "ndp-postgres",
  "db_user": "dev",
  "db_name": "notification_platform",
  "app_container": "ndp-app",
  "rabbit_mgmt_url": "http://localhost:15673",
  "rabbit_user": "dev",
  "rabbit_pass": "dev",

  "load": {
    "pattern": "ramp",
    "rate": 450,
    "duration_seconds": 40,
    "channels": ["EMAIL"],

    "//tenants": "List as many tenants as you want by name; the script creates any that don't exist and restarts the app (ndp-app) once so their workers register. Tenants persist between runs (reused, not deleted). 'weight' sets each tenant's share of the total rate — use unequal weights (e.g. 10 vs 1) for noisy-neighbour / fairness runs.",
    "tenants": [
      { "name": "ndp-test-a", "weight": 1 },
      { "name": "ndp-test-b", "weight": 10 },
      { "name": "ndp-test-c", "weight": 2 },
      { "name": "ndp-test-d", "weight": 3 }
    ],

    "webhook_url": "http://host.docker.internal:8080/actuator/health"
  },

  "chaos": {
    "enabled": false,
    "faults": [
      {
        "label": "broker_outage",
        "container": "ndp-rabbitmq",
        "action": "pause",
        "at_seconds": 10,
        "duration_seconds": 10
      }
    ]
  },

  "limits": {
    "drain_timeout_seconds": 500,
    "drain_poll_seconds": 3,
    "stall_seconds": 60
  }
}
