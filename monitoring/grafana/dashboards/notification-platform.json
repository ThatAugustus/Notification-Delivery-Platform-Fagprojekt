    {
      "title": "RabbitMQ Connections & Channels",
      "description": "Active connections and channels to RabbitMQ",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "rabbitmq_connections", "legendFormat": "connections", "refId": "A" },
        { "expr": "rabbitmq_channels", "legendFormat": "channels", "refId": "B" }
      ]
