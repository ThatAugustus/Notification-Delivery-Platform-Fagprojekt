  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔔 HTTP API",
      "type": "row"
    },

    {
      "title": "Request Rate (req/s)",
      "description": "HTTP requests per second hitting the API",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": false,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{uri=\"/api/v1/notifications\"}[30s])",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Request Latency (p95 / avg)",
      "description": "API response time — p95 and average",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{uri=\"/api/v1/notifications\"}[30s]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "rate(http_server_requests_seconds_sum{uri=\"/api/v1/notifications\"}[30s]) / rate(http_server_requests_seconds_count{uri=\"/api/v1/notifications\"}[30s])",
          "legendFormat": "avg",
          "refId": "B"
        }
      ]
    },

    {
      "title": "HTTP Error Rate",
      "description": "Percentage of non-2xx responses",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          },
          "unit": "percentunit",
          "min": 0, "max": 1
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status!~\"2..\"}[30s])) / sum(rate(http_server_requests_seconds_count[30s]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
